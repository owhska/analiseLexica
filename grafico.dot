digraph AFD_Numero {
    rankdir=LR;
    splines=true;
    nodesep=0.4;
    ranksep=0.6;

    node [shape=circle, style=filled, fillcolor="white", fontcolor="black"];
    edge [color="black"];

    // estado inicial
    inicio [shape=point];
    inicio -> E0;

    // organização em níveis (deixa mais retangular)
    {rank=same; E0;}
    {rank=same; E1; E2;}
    {rank=same; E3;}
    {rank=same; E4;}
    {rank=same; E5;}
    {rank=same; E6; E7;}

    // estados finais
    E3 [shape=doublecircle];
    E4 [shape=doublecircle];
    E7 [shape=doublecircle];

    // TRANSIÇÕES

    E0 -> E1 [label="+/-"];
    E0 -> E2 [label="."];
    E0 -> E3 [label="digit"];

    E1 -> E3 [label="digit"];
    E1 -> E2 [label="."];

    E2 -> E4 [label="digit"];

    E3 -> E3 [label="digit"];
    E3 -> E4 [label="."];
    E3 -> E5 [label="E"];

    E4 -> E4 [label="digit"];
    E4 -> E5 [label="E"];

    E5 -> E6 [label="+/-"];
    E5 -> E7 [label="digit"];

    E6 -> E7 [label="digit"];

    E7 -> E7 [label="digit"];
}
